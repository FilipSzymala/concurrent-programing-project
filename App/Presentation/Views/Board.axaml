<UserControl
	x:Class="Presentation.Views.Board"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:Presentation.ViewModels"
	xmlns:models="using:Presentation.Models"
	xmlns:helpers="using:Presentation.Helpers"
	x:DataType="vm:BoardViewModel">

	<Grid helpers:SizeObserver.Observe="True">
	<Border BorderBrush="Black" BorderThickness="2" Background="White"
	        HorizontalAlignment="Center" VerticalAlignment="Center">
		<ItemsControl ItemsSource="{Binding Balls}"
		              Width="{Binding ScaledBoardWidth}"
		              Height="{Binding ScaledBoardHeight}"
		              ClipToBounds="True">

			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<Canvas Background="Transparent" />
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>

			<ItemsControl.ItemTemplate>
				<DataTemplate x:DataType="models:BallListItem">
					<Ellipse Width="{Binding Diameter}"
					         Height="{Binding Diameter}">
						<Ellipse.Fill>
							<SolidColorBrush Color="{Binding Color}" />
						</Ellipse.Fill>
					</Ellipse>
				</DataTemplate>
			</ItemsControl.ItemTemplate>

			<ItemsControl.Styles>
				<Style Selector="ItemsControl > ContentPresenter" x:DataType="models:BallListItem">
					<Setter Property="Canvas.Left" Value="{Binding X}" />
					<Setter Property="Canvas.Top" Value="{Binding Y}" />
				</Style>
			</ItemsControl.Styles>
		</ItemsControl>
	</Border>
	</Grid>
</UserControl>
